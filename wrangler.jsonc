{
  // App estático (dist) + um Worker para as rotas /api/* (backend).
  "name": "clinica-podologia",
  "compatibility_date": "2026-06-01",
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    // O Worker roda primeiro só nas rotas de API; o resto é servido como arquivo.
    "run_worker_first": ["/api/*"]
  }
}
